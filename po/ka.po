#: src/gnome-chess.vala:883
msgid "Game is Drawn"
msgstr "თამაში ფრედ დასრულდა"

#. Game status when something goes wrong with the engine.
#: src/gnome-chess.vala:888
msgid "Oops!"
msgstr "უფს!"

#. Game status when Black is checkmated
#: src/gnome-chess.vala:901
msgid "Black is in check and cannot move."
msgstr "შავს შახი აქვს და მოძრაობა არ შეუძლია."

#. Game status when White is checkmated
#: src/gnome-chess.vala:904
msgid "White is in check and cannot move."
msgstr "თეთრს შახი აქვს და მოძრაობა არ შეუძლია."

#. Game status when the game terminates due to a stalemate
#: src/gnome-chess.vala:910
msgid "Player cannot move."
msgstr "მოთამაშეს სვლა არ აქვს."

#. Game status when the game is drawn due to the fifty move rule
#: src/gnome-chess.vala:914
msgid "No piece was taken or pawn moved in fifty moves."
msgstr "50 სვლაში არც ფიგურა მომკვდარა, არც პაიკი გადაადგილებულა."

#. Game status when the game is drawn due to the 75 move rule
#: src/gnome-chess.vala:918
msgid "No piece was taken or pawn moved in 75 moves."
msgstr "75 სვლაში არც ფიგურა მომკვდარა, არც პაიკი გადაადგილებულა."

#. Game status when the game ends due to Black's clock stopping
#: src/gnome-chess.vala:923
msgid "Black has run out of time."
msgstr "შავის დრო ამოიწურა."

#. Game status when the game ends due to White's clock stopping
#: src/gnome-chess.vala:926
msgid "White has run out of time."
msgstr "თეთრის დრო ამოიწურა."

#. Game status when the game is drawn due to the three-fold-repetition rule
#: src/gnome-chess.vala:932
msgid "The same board state has occurred three times."
msgstr "იგივე დაფის მდგომარეობა მოხდა სამჯერ."

#. Game status when the game is drawn due to the five-fold-repetition rule
#: src/gnome-chess.vala:936
msgid "The same board state has occurred five times."
msgstr "იგივე დაფის მდგომარეობა მოხდა ხუთჯერ."

#. Game status when the game is drawn due to the insufficient material rule
#: src/gnome-chess.vala:940
msgid "Neither player can checkmate."
msgstr "შახმატის თქმა არცერთს შეუძლია."

#. Game status when the game ends due to the black player resigning
#: src/gnome-chess.vala:945
msgid "Black has resigned."
msgstr "შავი დანებდა."

#. Game status when the game ends due to the white player resigning
#: src/gnome-chess.vala:948
msgid "White has resigned."
msgstr "თეთრი დანებდა."

#. Game status when a game is abandoned
#: src/gnome-chess.vala:954
msgid "The game has been abandoned."
msgstr "თამაში მიატოვეს."

#. Game status when the game ends due to a player dying during the game.
#: src/gnome-chess.vala:959
msgid "The game log says a player died!"
msgstr "თამაშის ჟურნალი ამბობს, რომ მოთამაშე მოკვდა!"

#. Game status when something goes wrong with the engine.
#: src/gnome-chess.vala:964
msgid "The computer player is confused. The game cannot continue."
msgstr "კომპიუტერი დაიბნა. თამაში ვერ გაგრძელდება."

#: src/gnome-chess.vala:989
msgid "Save Game?"
msgstr "შევინახო თამაში?"

#: src/gnome-chess.vala:995
msgid "_Abandon Game"
msgstr "თამაშის _მიტოვება"

#: src/gnome-chess.vala:996
msgid "Save game for later"
msgstr "თამაშის შენახვა გასაგრძელებლად"

#: src/gnome-chess.vala:1002
msgid "_Discard Game"
msgstr "თამაშის _გაუქმება"

#: src/gnome-chess.vala:1003
msgid "Save game log"
msgstr "თამაშის ჟურნალის შენახვა"

#: src/gnome-chess.vala:1037
msgid "Would you like to claim a draw?"
msgstr "გნებავთ ფრეს მოთხოვნა?"

#. Message in claim draw dialog when triggered by fifty-move rule
#: src/gnome-chess.vala:1043
msgid ""
"You may claim a draw because fifty moves have passed without a capture or "
"pawn advancement. (The computer player may still choose to claim a draw even "
"if you choose to keep playing.)"
msgstr ""
"თქვენ შეგიძლიათ, მოითხოვოთ ფრე, რადგან 50 სვლა გავიდა ისე, რომ ფიგურა არ "
"მომკვდარა და არც პაიკი წასულა წინ. (კომპიუტერს მაინც შეუძლია ფრეს არჩევა "
"მაშინაც კი, თუ თქვენ თამაშს აგრძელებთ)."

#. Message in claim draw dialog when triggered by three-fold repetition
#: src/gnome-chess.vala:1048
msgid ""
"You may claim a draw because the current board position has occurred three "
"times. (The computer player may still choose to claim a draw even if you "
"choose to keep playing.)"
msgstr ""
"თქვენ შეგიძლიათ მოითხოვოთ ფრეს, რადგან დაფის ამჟამინდელი პოზიცია სამჯერ "
"მოხდა. (კომპიუტერის მოთამაშემ შეიძლება მაინც აირჩიოს გათამაშება, მაშინაც კი, "
"თუ თქვენ აირჩევთ თამაშის გაგრძელებას.)"

#: src/gnome-chess.vala:1055 src/gnome-chess.vala:1085
msgid "_Keep Playing"
msgstr "_თამაშის გაგრძელება"

#: src/gnome-chess.vala:1056
msgid "_Claim Draw"
msgstr "ფრეს _მოთხოვნა"

#: src/gnome-chess.vala:1072
msgid "By starting a new game now, unsaved progress would be lost."
msgstr "ახლა ახალი თამაშის დაწყებით თამაში, რომელიც არ შეგინახავთ, დაიკარგება."

#: src/gnome-chess.vala:1082
msgid "Are you sure you want to resign?"
msgstr "მართლა გნებავთ, დანებდეთ?"

#. Text on warning dialog when player clicks Resign
#: src/gnome-chess.vala:1084
msgid "This makes sense if you plan to save the game as a record of your loss."
msgstr "ამას აზრი აქვს, თუ აპირებთ, თამაში წაგებად შეინახოთ."

#: src/gnome-chess.vala:1086
msgid "_Resign"
msgstr "_დანებება"

#: src/gnome-chess.vala:1215
msgid "translator-credits"
msgstr "თარგმანი-შესრულებულია"

